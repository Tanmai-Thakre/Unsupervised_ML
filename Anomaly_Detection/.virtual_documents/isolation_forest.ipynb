import pandas as pd
import matplotlib.pyplot as plt
from sklearn.preprocessing import StandardScaler


df = pd.read_csv("thyroid_dataset.csv")
df


X = df.drop("Outlier_label" , axis=1)
y = df["Outlier_label"]


# Scaling 
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)


X_scaled


from sklearn.ensemble import IsolationForest
clf = IsolationForest(n_estimators=200 ,contamination='auto',random_state=42)
labels = clf.fit_predict(X_scaled)
labels


# Visualise
from sklearn.decomposition import PCA

pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)


plt.figure(figsize=(8,6))
plt.scatter(x=X_pca[:,0] , y=X_pca[:,1] , c=labels)
plt.xlabel("PCA1")
plt.ylabel("PCA2")


import numpy as np
n_outliers = np.sum(labels == -1)
n_normal = np.sum(labels == 1)

print("no of outliers : " , n_outliers)
print("no of normal pts : " , n_normal)








from sklearn.neighbors import LocalOutlierFactor


neighbors = LocalOutlierFactor(contamination='auto')
labels = neighbors.fit_predict(X_scaled)


plt.figure(figsize=(8,6))
plt.scatter(x=X_pca[:,0] , y=X_pca[:,1] , c=labels)
plt.xlabel("PCA1")
plt.ylabel("PCA2")


n_outliers = np.sum(labels == -1)
n_normal = np.sum(labels == 1)

print("no of outliers : " , n_outliers)
print("no of normal pts : " , n_normal)



